{
  "name": "@carevo/contracts",
  "version": "0.4.1",
  "description": "",
  "license": "ISC",
  "author": "kucingkode",
  "scripts": {
    "build": "tsdown",
    "generate": "orval -c ./orval.config.ts"
  },
  "exports": {
    "./api": {
      "types": {
        "require": "./dist/api/index.d.cts",
        "default": "./dist/api/index.d.mts"
      },
      "default": {
        "require": "./dist/api/index.cjs",
        "default": "./dist/api/index.mjs"
      }
    },
    "./zod": {
      "types": {
        "require": "./dist/zod/index.d.cts",
        "default": "./dist/zod/index.d.mts"
      },
      "default": {
        "require": "./dist/zod/index.cjs",
        "default": "./dist/zod/index.mjs"
      }
    }
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "orval": "^8.5.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "zod": "^4.3.6"
  }
}
